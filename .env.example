# ============================================================
# Database Configuration
# ============================================================


# ============================================================
# AWS Configuration
# ============================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=media-automation-bucket

# S3 Folder Structure - Original Content
S3_ORIGINAL_IMAGES_FOLDER=original/images/
S3_ORIGINAL_VIDEOS_FOLDER=original/videos/
S3_ORIGINAL_AUDIOS_FOLDER=original/audios/

# S3 Folder Structure - AI Generated Content
S3_GENERATED_IMAGES_FOLDER=generated/images/
S3_GENERATED_AUDIOS_FOLDER=generated/audios/
S3_GENERATED_VIDEOS_FOLDER=generated/videos/

# ============================================================
# Audio Input Settings
# ============================================================
MAX_AUDIO_SIZE_MB=50
ALLOWED_AUDIO_FORMATS=mp3,wav,ogg,m4a,webm

# ============================================================
# Video Input Settings
# ============================================================
MAX_VIDEO_SIZE_MB=500
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,mkv,webm

# ============================================================
# Scraper Configuration
# ============================================================
MAX_ITEMS_PER_SOURCE=15
FETCH_FULL_ARTICLE=true
DELAY_BETWEEN_REQUESTS=1.5
OUTPUT_FILE=news_output.json

# ============================================================
# Logging Configuration
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Telegram Scraper Configuration
# ============================================================
TELEGRAM_TEXT_ONLY=true
TELEGRAM_MAX_POSTS=15

# ============================================================
# User Input API Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ============================================================
# Google Cloud Configuration (for STT)
# ============================================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
GOOGLE_CREDENTIALS_JSON=your_google_credentials_json

# ============================================================
# Claude API Configuration
# ============================================================
CLAUDE_API_KEY=your_claude_api_key

# ============================================================
# Gemini API Configuration
# ============================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ============================================================
# Application Configuration
# ============================================================
LOG_FILE=logs/app.log
DEBUG=False
ENVIRONMENT=production
